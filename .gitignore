# ============================================================
# AdTicks — .gitignore
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# --- Virtual Environments ---
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.venv312/

# --- Environment & Secrets ---
.env
.env.*
\!.env.example
\!frontend/.env.local.example
frontend/.env.local
frontend/.env.*.local

# --- Node / Next.js ---
node_modules/
.next/
out/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.yarn-integrity
.npm

# --- Docker ---
docker-compose.override.yml

# --- IDE & Editors ---
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# --- OS ---
.DS_Store
.DS_Store?
._*
.Spotlight-V7
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- Alembic ---
# Keep migrations but ignore pycache inside
backend/alembic/__pycache__/

# --- Logs ---
*.log
logs/
celerybeat-schedule
celerybeat.pid

# --- Uploads & Media ---
data/
uploads/
media/

# --- Misc ---
*.bak
*.tmp
*.temp
.cache/
